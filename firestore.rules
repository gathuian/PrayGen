rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for User entity
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'language', 'experienceLevel', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.email is string &&
             data.language in ['en', 'sw', 'fr', 'es'] &&
             data.experienceLevel in ['beginner', 'intermediate'] &&
             data.createdAt is timestamp;
    }

    // Validation for Prayer entity
    function isValidPrayer(data) {
      return data.keys().hasAll(['content', 'createdAt', 'ownerId']) &&
             data.content is string && data.content.size() <= 10000 &&
             data.createdAt is timestamp &&
             data.ownerId == request.auth.uid;
    }

    // Validation for Bookmark entity
    function isValidBookmark(data) {
      return data.keys().hasAll(['book', 'chapter', 'verse', 'text', 'createdAt']) &&
             data.book is string &&
             data.chapter is int &&
             data.createdAt is timestamp;
    }

    // Users collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'language', 'experienceLevel']);
      
      // Prayers subcollection
      match /prayers/{prayerId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidPrayer(request.resource.data);
        allow update: if isOwner(userId) && isValidPrayer(request.resource.data) &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'content']);
        allow delete: if isOwner(userId);
      }

      // Bookmarks subcollection
      match /bookmarks/{bookmarkId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidBookmark(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
