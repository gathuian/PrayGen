{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and preferences",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "language": { "type": "string", "enum": ["en", "sw", "fr", "es"] },
        "experienceLevel": { "type": "string", "enum": ["beginner", "intermediate"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "language", "experienceLevel"]
    },
    "Prayer": {
      "title": "Prayer",
      "description": "A generated or custom prayer",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "input": { "type": "string" },
        "type": { "type": "string" },
        "structure": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["content", "createdAt", "ownerId"]
    },
    "Bookmark": {
      "title": "Bible Bookmark",
      "description": "Saved bible passage",
      "type": "object",
      "properties": {
        "book": { "type": "string" },
        "chapter": { "type": "integer" },
        "verse": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Top-level user document"
    },
    "/users/{userId}/prayers/{prayerId}": {
      "schema": "Prayer",
      "description": "User's saved prayers"
    },
    "/users/{userId}/bookmarks/{bookmarkId}": {
      "schema": "Bookmark",
      "description": "User's bible bookmarks"
    }
  }
}
